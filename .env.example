# YouTube Download Agent Configuration Example
# Copy this file to .env and modify the values as needed
#
# Videos are stored as:  <this repo directory>/PROJECT_FOLDER/VIDEOS/<category>/
# (PATH is the folder containing download_videos.sh, download_list.md, and this file.)

# Subfolder for media under the project, or . for:  <project>/VIDEOS/<category>/
# Example:  PROJECT_FOLDER="media"  =>  <project>/media/VIDEOS/<category>/
PROJECT_FOLDER="."

# Maximum concurrent downloads (recommended: 2-4)
MAX_CONCURRENT_DOWNLOADS=2

# Optional: path to yt-dlp binary (defaults to Homebrew libexec when brew is available)
# YT_DLP="/opt/homebrew/opt/yt-dlp/libexec/bin/yt-dlp"

# Download quality preference
# Options:
# - "bestvideo[height<=1080]+bestaudio/best[height<=1080]" (1080p max)
# - "bestvideo[height<=720]+bestaudio/best[height<=720]" (720p max)
# - "best" (best available quality)
DOWNLOAD_QUALITY="bestvideo[height<=1080]+bestaudio/best[height<=1080]"
